{
  "name": "YSTools-Swift",
  "version": "1.0.0",
  "summary": "Common tools used in Swift projects.",
  "description": "Tools commonly used in Swift projects can facilitate rapid project development",
  "homepage": "https://github.com/peanutgao/YSTools-Swift",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "peanutgao": "peanutgao@hotmail.com"
  },
  "source": {
    "git": "https://github.com/peanutgao/YSTools-Swift.git",
    "tag": "1.0.0"
  },
  "platforms": {
    "ios": "13.0"
  },
  "swift_versions": [
    "5.9"
  ],
  "default_subspecs": [
    "Extension",
    "Create",
    "Utils"
  ],
  "resource_bundles": {
    "YSTools-Swift": [
      "YSTools-Swift/PrivacyInfo.xcprivacy"
    ]
  },
  "frameworks": [
    "UIKit",
    "Foundation"
  ],
  "subspecs": [
    {
      "name": "Extension",
      "source_files": "YSTools-Swift/Classes/Extension/**/*"
    },
    {
      "name": "Create",
      "source_files": "YSTools-Swift/Classes/Create/**/*",
      "dependencies": {
        "YSTools-Swift/Extension": []
      }
    },
    {
      "name": "Utils",
      "source_files": "YSTools-Swift/Classes/Utils/**/*"
    },
    {
      "name": "WebImage",
      "source_files": "YSTools-Swift/Classes/WebImage/**/*",
      "dependencies": {
        "YSTools-Swift/Extension": [],
        "YSTools-Swift/Create": [],
        "SDWebImage": [
          ">= 5.0.0"
        ]
      }
    }
  ],
  "swift_version": "5.9"
}
